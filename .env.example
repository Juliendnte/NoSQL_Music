# Copy this file to .env at the repo root, then run `docker compose up --build`.
# This single file feeds both the neo4j and api services in docker-compose.yml.

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123
NEO4J_DATABASE=neo4j
# Overridden to bolt://neo4j:7687 inside docker-compose.yml (container-to-container
# hostname); only relevant here if you run the API outside Docker (see back/README.md).
NEO4J_URI=bolt://localhost:7687

# --- MusicBrainz ---
# MusicBrainz requires an identifiable User-Agent and max 1 request/second.
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=MusicGraph/1.0 (contact@example.com)
MUSICBRAINZ_RATE_LIMIT_SECONDS=1.0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api
VITE_USE_MOCKS=false
